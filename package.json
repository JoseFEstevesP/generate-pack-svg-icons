{
	"name": "generate-pack-svg-icons",
	"version": "2.0.0",
	"description": "Generador de paquetes SVG en Node.js con optimización SVGO",
	"type": "module",
	"main": "src/index.js",
	"scripts": {
		"generate": "node generate.js",
		"dev": "node index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src/ tests/",
		"lint:fix": "eslint src/ tests/ --fix",
		"format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
		"format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
	},
	"keywords": [
		"svg",
		"icons",
		"pack",
		"sprite",
		"generator",
		"svgo"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"svgo": "^3.3.2",
		"inquirer": "^12.0.1",
		"chalk": "^5.4.1",
		"figlet": "^1.8.0",
		"cli-table3": "^0.6.5"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"vitest": "^3.1.1",
		"eslint": "^9.0.0",
		"prettier": "^3.5.0"
	}
}
