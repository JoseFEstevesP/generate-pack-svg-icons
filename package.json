{
  "name": "generate-pack-svg-icons",
  "version": "2.1.0",
  "description": "Generador de paquetes SVG en Node.js con optimización SVGO",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "svg-packer": "./src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "keywords": [
    "svg",
    "icons",
    "pack",
    "sprite",
    "generator",
    "svgo"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "fast-xml-parser": "^4.5.7",
    "figlet": "^1.8.0",
    "inquirer": "^12.0.1",
    "minimist": "^1.2.8",
    "svgo": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.5.0",
    "vitest": "^3.1.1"
  }
}
